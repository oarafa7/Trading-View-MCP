# Gateway
PORT=4000
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Auth (dev). With AUTH_REQUIRED unset, requests with no/invalid token default to an owner
# principal (zero-config). Set AUTH_REQUIRED=true to reject missing/invalid tokens.
# Dev bearer tokens map to roles: dev-owner, dev-admin, dev-operator, dev-viewer.
AUTH_REQUIRED=
# Token the web app sends (the in-app role switcher overrides this via localStorage).
NEXT_PUBLIC_DEV_TOKEN=dev-owner

# Provider credentials (all optional — the "mock" model works with none of these set).
# Set the ones you have keys for; the matching seeded models become usable.
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=

# Ollama (local). Default http://localhost:11434 if unset.
OLLAMA_BASE_URL=

# Web (apps/web)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
