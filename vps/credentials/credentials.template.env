# Hermes AI Agent — VPS Credentials Template
# Copy this file to credentials.env and fill in real values
# NEVER commit credentials.env to git

# ── Hostinger VPS ──────────────────────────────────────────────────────────────
VPS_HOST=            # e.g. 123.45.67.89
VPS_USER=            # e.g. root or hermes
VPS_SSH_PORT=22
VPS_SSH_KEY_PATH=    # e.g. ~/.ssh/hermes_vps_rsa

# ── Hermes AI Agent ────────────────────────────────────────────────────────────
HERMES_API_KEY=
HERMES_API_SECRET=
HERMES_WEBHOOK_SECRET=

# ── Anthropic / Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── TradingView ────────────────────────────────────────────────────────────────
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hermes
DB_USER=
DB_PASSWORD=

# ── Broker / Exchange ──────────────────────────────────────────────────────────
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=

# ── Notifications ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
